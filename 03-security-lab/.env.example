# ─────────────────────────────────────────────────────────────────────────────
# M365 Security Lab — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Application
PORT=3000
NODE_ENV=development

# Microsoft Entra ID (Azure AD) — App Registration
CLIENT_ID=YOUR_APP_CLIENT_ID_GUID
CLIENT_SECRET=YOUR_APP_CLIENT_SECRET
TENANT_ID=YOUR_TENANT_ID_GUID
REDIRECT_URI=http://localhost:3000

# RBAC Group Object IDs (from Entra ID)
ADMIN_GROUP_ID=YOUR_ADMIN_GROUP_OBJECT_ID_GUID
MANAGER_GROUP_ID=YOUR_MANAGER_GROUP_OBJECT_ID_GUID
EMPLOYEE_GROUP_ID=YOUR_EMPLOYEE_GROUP_OBJECT_ID_GUID

# CORS — Comma-separated list of allowed origins
# Example: http://localhost:3000,https://yourapp.azurewebsites.net
ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info

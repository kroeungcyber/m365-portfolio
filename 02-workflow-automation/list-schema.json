{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json",
  "description": "SharePoint Online — Leave Requests List Schema (Power Platform backend)",
  "version": "1.0.0",
  "listDefinition": {
    "title": "Leave Requests",
    "description": "Stores all employee leave request submissions and their multi-stage approval states",
    "template": "GenericList",
    "enableVersioning": true,
    "majorVersionLimit": 10,
    "enableModeration": false,
    "onQuickLaunch": true,
    "contentTypesEnabled": true,
    "contentTypes": [
      {
        "name": "Leave Request",
        "description": "Standard leave request form content type",
        "group": "HR Content Types"
      }
    ],
    "columns": [
      {
        "internalName": "Title",
        "displayName": "Request Title",
        "type": "Text",
        "required": true,
        "description": "Auto-generated by Power Automate: LEAVE-{EmployeeID}-{YYYY-MM-DD}"
      },
      {
        "internalName": "EmployeeName",
        "displayName": "Employee Name",
        "type": "User",
        "required": true,
        "allowMultipleValues": false,
        "description": "Populated from Entra ID profile via Power Apps context"
      },
      {
        "internalName": "EmployeeID",
        "displayName": "Employee ID",
        "type": "Text",
        "required": true,
        "maxLength": 20
      },
      {
        "internalName": "Department",
        "displayName": "Department",
        "type": "Choice",
        "required": true,
        "choices": ["HR", "Finance", "IT", "Legal", "Operations", "Marketing", "Executive"],
        "defaultValue": "IT"
      },
      {
        "internalName": "LeaveType",
        "displayName": "Leave Type",
        "type": "Choice",
        "required": true,
        "choices": [
          "Annual Leave",
          "Sick Leave",
          "Personal Leave",
          "Parental Leave",
          "Bereavement Leave",
          "Unpaid Leave"
        ],
        "defaultValue": "Annual Leave"
      },
      {
        "internalName": "StartDate",
        "displayName": "Start Date",
        "type": "DateTime",
        "required": true,
        "dateOnly": true,
        "description": "First day of requested leave (inclusive)"
      },
      {
        "internalName": "EndDate",
        "displayName": "End Date",
        "type": "DateTime",
        "required": true,
        "dateOnly": true,
        "description": "Last day of requested leave (inclusive)"
      },
      {
        "internalName": "TotalDays",
        "displayName": "Total Working Days",
        "type": "Calculated",
        "required": false,
        "formula": "=NETWORKDAYS([Start Date],[End Date])",
        "outputType": "Number",
        "description": "Calculated: working days between Start Date and End Date (excludes weekends)"
      },
      {
        "internalName": "Reason",
        "displayName": "Reason",
        "type": "Note",
        "required": true,
        "richText": false,
        "maxLength": 500,
        "description": "Employee's explanation for the leave request"
      },
      {
        "internalName": "ApprovalStatus",
        "displayName": "Approval Status",
        "type": "Choice",
        "required": true,
        "choices": [
          "Pending Manager Review",
          "Pending HR Review",
          "Approved",
          "Rejected",
          "Cancelled"
        ],
        "defaultValue": "Pending Manager Review"
      },
      {
        "internalName": "ManagerApprover",
        "displayName": "Manager Approver",
        "type": "User",
        "required": false,
        "description": "Set by Power Automate: direct manager resolved via Graph API GET /users/{id}/manager"
      },
      {
        "internalName": "ManagerDecision",
        "displayName": "Manager Decision",
        "type": "Choice",
        "required": false,
        "choices": ["Approved", "Rejected", "Pending"],
        "defaultValue": "Pending"
      },
      {
        "internalName": "ManagerComments",
        "displayName": "Manager Comments",
        "type": "Note",
        "required": false,
        "richText": false,
        "maxLength": 300,
        "description": "Manager's notes recorded in the Teams Adaptive Card approval response"
      },
      {
        "internalName": "ManagerDecisionDate",
        "displayName": "Manager Decision Date",
        "type": "DateTime",
        "required": false,
        "description": "Timestamp set by Power Automate when manager completes their approval action"
      },
      {
        "internalName": "HRApprover",
        "displayName": "HR Approver",
        "type": "User",
        "required": false,
        "description": "Set by Power Automate: assigned HR officer from the HR-Officers Entra ID group"
      },
      {
        "internalName": "HRDecision",
        "displayName": "HR Decision",
        "type": "Choice",
        "required": false,
        "choices": ["Approved", "Rejected", "Pending"],
        "defaultValue": "Pending"
      },
      {
        "internalName": "HRComments",
        "displayName": "HR Comments",
        "type": "Note",
        "required": false,
        "richText": false,
        "maxLength": 300
      },
      {
        "internalName": "HRDecisionDate",
        "displayName": "HR Decision Date",
        "type": "DateTime",
        "required": false,
        "description": "Timestamp set by Power Automate when HR completes their approval action"
      },
      {
        "internalName": "CalendarEventID",
        "displayName": "Calendar Event ID",
        "type": "Text",
        "required": false,
        "description": "Outlook calendar event ID created via Graph API upon final approval"
      },
      {
        "internalName": "NotificationSent",
        "displayName": "Notification Sent",
        "type": "Boolean",
        "required": false,
        "defaultValue": false,
        "description": "Set to true by Power Automate once Teams/email notification is dispatched"
      },
      {
        "internalName": "SubmittedDate",
        "displayName": "Submitted Date",
        "type": "DateTime",
        "required": false,
        "description": "Auto-set by Power Automate trigger on initial item creation"
      }
    ],
    "views": [
      {
        "name": "My Leave Requests",
        "description": "Filtered to the current user's submissions — default view in the Power Apps canvas app",
        "defaultView": true,
        "query": "<Where><Eq><FieldRef Name='EmployeeName' /><Value Type='Integer'><UserID /></Value></Eq></Where>",
        "orderBy": "<OrderBy><FieldRef Name='SubmittedDate' Ascending='FALSE' /></OrderBy>",
        "columns": ["Title", "LeaveType", "StartDate", "EndDate", "TotalDays", "ApprovalStatus"]
      },
      {
        "name": "Pending Manager Approval",
        "description": "Items awaiting manager review — surfaced in the Power Automate approval task and manager Teams notification",
        "query": "<Where><Eq><FieldRef Name='ApprovalStatus' /><Value Type='Choice'>Pending Manager Review</Value></Eq></Where>",
        "columns": ["Title", "EmployeeName", "Department", "LeaveType", "StartDate", "EndDate", "TotalDays", "Reason"]
      },
      {
        "name": "Pending HR Approval",
        "description": "Manager-approved items awaiting HR sign-off",
        "query": "<Where><Eq><FieldRef Name='ApprovalStatus' /><Value Type='Choice'>Pending HR Review</Value></Eq></Where>",
        "columns": ["Title", "EmployeeName", "Department", "LeaveType", "StartDate", "EndDate", "TotalDays", "ManagerDecision", "ManagerComments"]
      },
      {
        "name": "All Requests (HR Admin)",
        "description": "Full audit view — restricted to HR Admins via list-level permissions",
        "query": "",
        "orderBy": "<OrderBy><FieldRef Name='SubmittedDate' Ascending='FALSE' /></OrderBy>",
        "columns": ["Title", "EmployeeName", "EmployeeID", "Department", "LeaveType", "StartDate", "EndDate", "TotalDays", "ApprovalStatus", "ManagerDecision", "HRDecision", "SubmittedDate"]
      }
    ],
    "permissions": {
      "breakRoleInheritance": true,
      "copyRoleAssignments": false,
      "roleAssignments": [
        {
          "group": "M365-Employees",
          "permission": "Contribute",
          "note": "Employees can submit and edit their own items. Per-item permissions restrict visibility to own submissions only."
        },
        {
          "group": "M365-Managers",
          "permission": "Edit",
          "note": "Managers can view and update items in their department via the Pending Manager Approval view."
        },
        {
          "group": "HR-Members",
          "permission": "Full Control",
          "note": "HR has full visibility and administrative control over all leave requests."
        }
      ]
    },
    "columnFormatting": {
      "ApprovalStatus": {
        "Approved": { "background": "#DFF6DD", "textColor": "#107C10", "icon": "CheckMark" },
        "Rejected": { "background": "#FDE7E9", "textColor": "#D13438", "icon": "Cancel" },
        "Pending Manager Review": { "background": "#FFF4CE", "textColor": "#835B00", "icon": "Clock" },
        "Pending HR Review": { "background": "#DEECF9", "textColor": "#004578", "icon": "Clock" },
        "Cancelled": { "background": "#F3F2F1", "textColor": "#605E5C", "icon": "Blocked" }
      }
    }
  }
}
